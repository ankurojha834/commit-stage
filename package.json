{
  "name": "commit-sage",
  "version": "2.0.0",
  "description": "An AI-powered CLI tool that automatically generates meaningful, well-structured git commit messages from your staged changes. Supports free offline mode via Ollama, mood personalities, git personality scoring, and team leaderboards.",
  "bin": {
    "commit-sage": "./bin/cli.js"
  },
  "main": "./src/index.js",
  "type": "module",
  "scripts": {
    "start": "node bin/cli.js",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "cli",
    "ollama",
    "openai",
    "conventional-commits",
    "developer-tools",
    "automation"
  ],
  "author": "Ankur Ojha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ankurojha/commit-sage"
  },
  "homepage": "https://github.com/ankurojha/commit-sage#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0"
  }
}